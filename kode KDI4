import random
import math

# Fungsi untuk mengecek bilangan prima
def cek_prima(x):
    if x < 2:
        return False
    for i in range(2, int(x ** 0.5) + 1):
        if x % i == 0:
            return False
    return True

# Fungsi untuk mendapatkan bilangan prima secara acak
def ambil_prima():
    while True:
        angka = random.randrange(100, 300)
        if cek_prima(angka):
            return angka

# Fungsi mencari invers modulo
def invers_modulo(a, m):
    m0 = m
    y = 0
    x = 1

    if m == 1:
        return 0

    while a > 1:
        q = a // m
        t = m

        m = a % m
        a = t
        t = y

        y = x - q * y
        x = t

    if x < 0:
        x += m0

    return x

# PEMBANGKITAN KUNCI RSA

p = ambil_prima()
q = ambil_prima()

while p == q:
    q = ambil_prima()

n = p * q
phi = (p - 1) * (q - 1)

# memilih e yang relatif prima dengan phi
e = random.randrange(2, phi)

while math.gcd(e, phi) != 1:
    e = random.randrange(2, phi)

# menghitung kunci privat
d = invers_modulo(e, phi)

print("Bilangan Prima p :", p)
print("Bilangan Prima q :", q)
print("Nilai n :", n)
print("Nilai phi :", phi)
print("Public Key :", (e, n))
print("Private Key :", (d, n))

# ENKRIPSI

pesan = 15
cipher = pow(pesan, e, n)

print("\nPesan Asli :", pesan)
print("Hasil Enkripsi :", cipher)

# DEKRIPSI

hasil_dekripsi = pow(cipher, d, n)

print("Hasil Dekripsi :", hasil_dekripsi)
